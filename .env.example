# ─── DATABASE ───────────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://exyra:exyra_pass_2024@localhost:3306/exyra_meet
DATABASE_URL_SYNC=mysql+pymysql://exyra:exyra_pass_2024@localhost:3306/exyra_meet

# ─── APP ────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-32-char-string
DEBUG=false

# ─── GOOGLE OAUTH ───────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create project → Enable Google Calendar API + Google Meet API
# 3. OAuth 2.0 credentials → Web application
# 4. Authorized redirect URIs: http://localhost:3000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GOOGLE SERVICE ACCOUNT (for Calendar/Meet auto-creation) ─
# 1. IAM & Admin → Service Accounts → Create
# 2. Roles: Calendar Editor
# 3. Download JSON key → place at backend/credentials/service_account.json
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json
GOOGLE_CALENDAR_ID=primary

# ─── GMAIL / SMTP ───────────────────────────────────────────
# Use Gmail App Password: https://myaccount.google.com/apppasswords
GMAIL_SENDER_EMAIL=your-email@gmail.com
GMAIL_SENDER_NAME=Exyra Technologies
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# ─── WHATSAPP CLOUD API ─────────────────────────────────────
# 1. Go to https://developers.facebook.com/
# 2. Create app → WhatsApp → Set up
# 3. Copy Phone Number ID and Permanent Token
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=exyra_verify_token

# ─── FRONTEND ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=  # same as GOOGLE_CLIENT_ID above
